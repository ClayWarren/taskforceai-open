{
  "name": "@taskforceai/console",
  "version": "1.0.0",
  "private": true,
  "description": "TaskForceAI Developer Console",
  "license": "MIT",
  "type": "module",
  "exports": {
    "./app/*": "./app/*",
    "./logger": {
      "types": "./app/lib/logger.ts",
      "default": "./app/lib/logger.ts"
    },
    "./config/*": {
      "types": "./app/lib/config/*",
      "default": "./app/lib/config/*"
    },
    "./lib/*": {
      "types": "./app/lib/*",
      "default": "./app/lib/*"
    },
    "./types/*": {
      "types": "./app/lib/types/*",
      "default": "./app/lib/types/*"
    },
    "./utils/*": {
      "types": "./app/lib/utils/*",
      "default": "./app/lib/utils/*"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "NODE_OPTIONS='--no-deprecation' vite build",
    "build:vercel": "bun run scripts/vercel-build.ts",
    "build:ci": "bun run typecheck && NODE_OPTIONS='--no-deprecation' vite build",
    "build:desktop": "NODE_OPTIONS='--no-deprecation' vite build --config vite.config.desktop.ts",
    "start": "node .output/server/index.mjs",
    "test": "cd ../.. && bun run tests/run-frontend-bun.ts --scope=console",
    "lint": "bun x oxlint --config ../../oxlint.config.json",
    "lint:fix": "bun x oxlint --config ../../oxlint.config.json --fix",
    "typecheck": "bun ../../scripts/dev/generate-route-trees.ts console && ../../node_modules/.bin/tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@sentry/react": "^10.62.0",
    "@t3-oss/env-core": "^0.13.11",
    "@tanstack/react-query": "^5.101.1",
    "@tanstack/react-router": "1.170.16",
    "@tanstack/react-start": "1.168.26",
    "@taskforceai/client-runtime": "workspace:*",
    "@taskforceai/contracts": "workspace:*",
    "@taskforceai/design-tokens": "workspace:*",
    "@taskforceai/observability": "workspace:*",
    "@taskforceai/shared": "workspace:*",
    "@taskforceai/voice": "workspace:*",
    "@tauri-apps/api": "^2.11.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/og": "^0.11.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "4.4.4",
    "dompurify": "^3.4.11",
    "dotenv": "^17.4.2",
    "fuse.js": "^7.4.2",
    "i18next": "^26.3.3",
    "lucide-react": "^1.21.0",
    "marked": "^18.0.5",
    "prismjs": "^1.30.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-i18next": "^17.0.8",
    "tailwind-merge": "^3.6.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/vite": "^4.3.1",
    "@taskforceai/toolchain": "workspace:*",
    "@types/node": "^25.9.4",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "fake-indexeddb": "^6.2.5",
    "nitro": "3.0.260610-beta",
    "tailwindcss": "^4.3.1",
    "vite": "^8.0.16",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "packageManager": "bun@1.3.14"
}
