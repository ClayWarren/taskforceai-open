{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "~/.bun/bin/bun run build:vercel",
  "installCommand": "cd ../.. && curl -fsSL https://bun.sh/install | bash -s \"bun-v1.3.14\" && ~/.bun/bin/bun install --no-save",
  "framework": null,
  "redirects": [
    {
      "source": "/auth/logout",
      "destination": "https://auth.taskforceai.chat/api/v1/auth/logout",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/auth/:path*",
      "destination": "https://auth.taskforceai.chat/api/auth/:path*"
    },
    {
      "source": "/api/v1/auth/:path*",
      "destination": "https://auth.taskforceai.chat/api/v1/auth/:path*"
    },
    {
      "source": "/api/v1/:path*",
      "destination": "https://api.taskforceai.chat/api/v1/:path*"
    }
  ]
}
