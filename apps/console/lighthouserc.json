{
  "ci": {
    "collect": {
      "numberOfRuns": 3,
      "startServerCommand": "bash -lc 'if [ -x ./scripts/perf/perf-tanstack-app.sh ]; then ./scripts/perf/perf-tanstack-app.sh console 3013 /__lhci__/console; else ../../scripts/perf/perf-tanstack-app.sh console 3013 /__lhci__/console; fi'",
      "startServerReadyPattern": "Ready",
      "startServerReadyTimeout": 120000,
      "url": ["http://127.0.0.1:3013/__lhci__/console"],
      "settings": {
        "preset": "desktop",
        "skipAudits": ["uses-http2"],
        "chromeFlags": "--ignore-certificate-errors --allow-insecure-localhost --disable-storage-reset --no-sandbox --disable-setuid-sandbox --disable-dev-shm-usage --disable-features=SafeBrowsing --disable-gpu --headless=new"
      }
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.8 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.7 }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 2500 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 3000 }],
        "network-dependency-tree-insight": ["warn", { "minScore": 0.9 }],
        "valid-source-maps": ["warn", { "minScore": 0.9 }],
        "unused-javascript": ["warn", { "maxLength": 2 }],
        "redirects": ["warn", { "minScore": 0.9 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
