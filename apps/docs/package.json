{
  "name": "@taskforceai/docs",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "bun ../../scripts/dev/sync-public-assets.ts && cp ../../packages/contracts/openapi/openapi.yaml public/openapi.yaml || true",
    "dev": "bun scripts/validate-docs.ts",
    "prebuild": "bun ../../scripts/dev/sync-public-assets.ts && cp ../../CHANGELOG.md . || true; cp ../../packages/contracts/openapi/openapi.yaml public/openapi.yaml || true",
    "build": "bun scripts/validate-docs.ts",
    "start": "bun run build",
    "test": "bun test --pass-with-no-tests",
    "typecheck": "../../node_modules/.bin/tsc --noEmit",
    "lint": "bun x oxlint --config ../../oxlint.config.json"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "7.0.2"
  },
  "packageManager": "bun@1.3.14"
}
