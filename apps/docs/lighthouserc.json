{
  "ci": {
    "collect": {
      "numberOfRuns": 3,
      "startServerCommand": "./scripts/perf/perf-marketing.sh",
      "startServerReadyPattern": "Ready",
      "startServerReadyTimeout": 120000,
      "url": ["http://127.0.0.1:3001/home"],
      "settings": {
        "preset": "desktop",
        "skipAudits": ["uses-http2"],
        "chromeFlags": "--ignore-certificate-errors --allow-insecure-localhost --disable-storage-reset --no-sandbox --disable-setuid-sandbox --disable-dev-shm-usage --disable-features=SafeBrowsing --disable-gpu --headless=new"
      }
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.9 }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 1500 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 2000 }],
        "unused-javascript": ["warn", { "maxLength": 2 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
