{
  "name": "taskforceai-mobile",
  "version": "0.1.0",
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=24.13.0",
    "bun": ">=1.3.14"
  },
  "main": "index.js",
  "scripts": {
    "nativewind:build": "node ./scripts/build-nativewind-css.mjs",
    "eas-build-post-install": "node ./scripts/build-nativewind-css.mjs",
    "prestart": "bun run nativewind:build",
    "preexport": "bun run nativewind:build",
    "start": "bun run nativewind:build && expo start",
    "android": "bun run nativewind:build && expo run:android",
    "ios": "bun run nativewind:build && expo run:ios",
    "web": "bun run nativewind:build && expo start --web",
    "ota:update": "node ./scripts/eas-update.mjs",
    "ota:preview": "node ./scripts/eas-update.mjs --profile preview",
    "ota:production": "node ./scripts/eas-update.mjs --profile production",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "typecheck": "bun run nativewind:build && ../../node_modules/.bin/tsgo --noEmit",
    "test": "bun run test:logic && bun run test:ui",
    "test:logic": "bun run nativewind:build && bun run ./test/run-logic-tests.ts",
    "test:ui": "bun run nativewind:build && cross-env USE_RN_SHIMS=false jest --runInBand --forceExit",
    "test:watch": "bun run nativewind:build && cross-env USE_RN_SHIMS=false jest --watch",
    "test:unit": "bun run nativewind:build && cross-env USE_RN_SHIMS=false jest --runInBand --forceExit",
    "test:integration": "bun run nativewind:build && cross-env USE_RN_SHIMS=false jest --runInBand --runTestsByPath src/__tests__/api-integration.test.ts",
    "test:offline": "bun run nativewind:build && cross-env USE_RN_SHIMS=false jest --runInBand --runTestsByPath src/__tests__/offline-sync.test.ts",
    "test:coverage:logic": "bun run nativewind:build && bun run ./test/run-logic-coverage.ts",
    "test:coverage:ui": "bun run nativewind:build && cross-env USE_RN_SHIMS=false jest --coverage --runInBand --forceExit --coverageThreshold='{}'",
    "test:coverage": "bun run test:coverage:logic && bun run test:coverage:ui; bun run ./test/merge-coverage.ts",
    "test:coverage:open": "bun run test:coverage && open coverage/merged/index.html || genhtml coverage/merged/lcov.info -o coverage/merged/html && open coverage/merged/html/index.html",
    "detox:ios:build": "bunx detox build --config-path ./detox.config.js --configuration ios.sim.debug",
    "detox:ios:test": "bunx detox test --config-path ./detox.config.js --configuration ios.sim.debug",
    "detox:ios:build:release": "bunx detox build --config-path ./detox.config.js --configuration ios.sim.release",
    "detox:ios:test:release": "bunx detox test --config-path ./detox.config.js --configuration ios.sim.release",
    "detox:android:build": "bunx detox build --config-path ./detox.config.js --configuration android.emu.debug",
    "detox:android:test": "bunx detox test --config-path ./detox.config.js --configuration android.emu.debug"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/metro-runtime": "56.0.14",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@react-native-async-storage/async-storage": "~3.1.1",
    "@react-native-community/netinfo": "12.0.1",
    "@react-native-voice/voice": "^3.2.4",
    "@sentry/react-native": "~8.13.0",
    "@shopify/flash-list": "2.3.1",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-persist-client": "^5.101.0",
    "@taskforceai/client-runtime": "workspace:*",
    "@taskforceai/contracts": "workspace:*",
    "@taskforceai/design-tokens": "workspace:*",
    "@taskforceai/observability": "workspace:*",
    "@taskforceai/persistence": "workspace:*",
    "@taskforceai/react-core": "workspace:*",
    "@taskforceai/shared": "workspace:*",
    "@taskforceai/sync-client": "workspace:*",
    "@taskforceai/ui-kit": "workspace:*",
    "@taskforceai/voice": "workspace:*",
    "@types/react": "~19.2.17",
    "cockatiel": "^4.0.0",
    "drizzle-orm": "^0.45.2",
    "expo": "56.0.9",
    "expo-apple-authentication": "~56.0.4",
    "expo-auth-session": "~56.0.13",
    "expo-build-properties": "~56.0.17",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "~56.0.17",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "~56.0.19",
    "expo-device": "~56.0.4",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.7",
    "expo-font": "~56.0.5",
    "expo-glass-effect": "~56.0.4",
    "expo-image-picker": "~56.0.16",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.13",
    "expo-modules-core": "56.0.15",
    "expo-notifications": "~56.0.16",
    "expo-router": "~56.2.9",
    "expo-secure-store": "~56.0.4",
    "expo-sharing": "~56.0.16",
    "expo-speech": "~56.0.3",
    "expo-splash-screen": "~56.0.10",
    "expo-sqlite": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.18",
    "expo-video": "~56.1.2",
    "expo-web-browser": "~56.0.5",
    "i18next": "^26.3.1",
    "lucide-react-native": "^1.17.0",
    "nativewind": "5.0.0-preview.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^17.0.8",
    "react-native": "0.85.3",
    "react-native-css": "^3.0.7",
    "react-native-markdown-display": "^7.0.2",
    "react-native-purchases": "10.3.0",
    "react-native-reanimated": "~4.4.1",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "~4.25.2",
    "react-native-sse": "^1.2.1",
    "react-native-svg": "15.15.5",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.9.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@babel/plugin-transform-react-jsx": "^7.29.7",
    "@babel/runtime": "^7.29.7",
    "@jest/globals": "30.4.1",
    "@jest/reporters": "30.4.1",
    "@react-native/jest-preset": "0.85.3",
    "@tailwindcss/postcss": "^4.3.0",
    "@taskforceai/toolchain": "workspace:*",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "13.3.3",
    "@types/detox": "^18.1.3",
    "@types/jest": "30.0.0",
    "@types/node": "^25.9.2",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "~56.0.14",
    "c8": "^11.0.0",
    "cross-env": "^10.1.0",
    "detox": "^20.51.3",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eas-cli": "^20.1.0",
    "jest": "~30.4.2",
    "jest-environment-node": "30.4.1",
    "jest-expo": "~56.0.4",
    "metro-config": "0.84.4",
    "metro-resolver": "0.84.4",
    "postcss": "^8.5.15",
    "postcss-value-parser": "^4.2.0",
    "react-test-renderer": "19.2.3",
    "tailwindcss": "^4.3.0",
    "typescript": "npm:@typescript/native-preview@7.0.0-dev.20260612.1"
  },
  "expo": {
    "install": {
      "exclude": [
        "react",
        "react-dom",
        "react-native-reanimated"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@react-native-voice/voice"
        ]
      }
    }
  },
  "private": true
}
