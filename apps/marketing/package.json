{
  "name": "@taskforceai/marketing",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun ../../scripts/dev/sync-public-assets.ts && vite dev",
    "build": "bun ../../scripts/dev/sync-public-assets.ts && NODE_OPTIONS='--no-deprecation' vite build",
    "build:vercel": "bun ../../scripts/dev/sync-public-assets.ts && bun run scripts/vercel-build.ts",
    "start": "node scripts/start-server.mjs",
    "test": "bun test --preload ./bun-setup.ts",
    "lint": "bun x oxlint --config ../../oxlint.config.json",
    "typecheck": "bun ../../scripts/dev/generate-route-trees.ts marketing && ../../node_modules/.bin/tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@radix-ui/react-dialog": "^1.1.18",
    "@tanstack/react-router": "1.170.17",
    "@tanstack/react-start": "1.168.27",
    "@taskforceai/config": "workspace:*",
    "@taskforceai/design-tokens": "workspace:*",
    "@taskforceai/observability": "workspace:*",
    "@taskforceai/react-core": "workspace:*",
    "@taskforceai/ui-kit": "workspace:*",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "marked": "^18.0.5",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.10.6",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.1",
    "typescript": "7.0.2",
    "vite": "8.1.4"
  },
  "packageManager": "bun@1.3.14"
}
