{
  "name": "@taskforceai/web",
  "version": "1.0.0",
  "private": true,
  "description": "TaskForceAI Web Application",
  "license": "MIT",
  "type": "module",
  "imports": {
    "#tests/*": "../../tests/*.ts",
    "#web/*": "./app/*.ts",
    "#lib/*": "./app/lib/*.ts"
  },
  "exports": {
    "./app/*": "./app/*",
    "./logger": "./app/lib/logger.ts",
    "./config/*": "./app/lib/config/*",
    "./lib/*": "./app/lib/*",
    "./types/*": "./app/lib/types/*",
    "./utils/*": "./app/lib/utils/*"
  },
  "scripts": {
    "dev": "bun ../../scripts/dev/generate-desktop-app-server-types.ts && bun ../../scripts/dev/sync-public-assets.ts && vite",
    "dev:desktop": "bun ../../scripts/dev/generate-desktop-app-server-types.ts && bun ../../scripts/dev/sync-public-assets.ts && NODE_OPTIONS='--disable-warning=DEP0205' vite --host 127.0.0.1 --port 3210 --config vite.config.desktop.ts",
    "build": "bun ../../scripts/dev/generate-desktop-app-server-types.ts && bun ../../scripts/dev/sync-public-assets.ts && NODE_OPTIONS='--no-deprecation' vite build",
    "build:vercel": "bun ../../scripts/dev/sync-public-assets.ts && bun run scripts/vercel-build.ts",
    "build:ci": "bun run typecheck && bun ../../scripts/dev/generate-desktop-app-server-types.ts && bun ../../scripts/dev/sync-public-assets.ts && NODE_OPTIONS='--no-deprecation' vite build",
    "build:desktop": "bun ../../scripts/dev/generate-desktop-app-server-types.ts && bun ../../scripts/dev/sync-public-assets.ts && NODE_OPTIONS='--no-deprecation' vite build --config vite.config.desktop.ts",
    "start": "node .output/server/index.mjs",
    "lint": "bun x oxlint --deny-warnings --config ../../oxlint.config.json --type-aware --tsconfig tsconfig.json .",
    "lint:fix": "bun x oxlint --config ../../oxlint.config.json --type-aware --tsconfig tsconfig.json --fix .",
    "typecheck": "bun ../../scripts/dev/generate-desktop-app-server-types.ts && bun ../../scripts/dev/sync-public-assets.ts && bun ../../scripts/dev/generate-route-trees.ts web && ../../node_modules/.bin/tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^4.0.16",
    "@ai-sdk/react": "^4.0.23",
    "@fontsource-variable/inter": "^5.2.8",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@radix-ui/react-alert-dialog": "^1.1.18",
    "@sentry/react": "^10.62.0",
    "@tanstack/react-query": "^5.101.1",
    "@tanstack/react-router": "1.170.17",
    "@tanstack/react-start": "1.168.27",
    "@taskforceai/api-client": "workspace:*",
    "@taskforceai/browser-runtime": "workspace:*",
    "@taskforceai/client-core": "workspace:*",
    "@taskforceai/client-runtime": "workspace:*",
    "@taskforceai/config": "workspace:*",
    "@taskforceai/contracts": "workspace:*",
    "@taskforceai/design-tokens": "workspace:*",
    "@taskforceai/feature-flags": "workspace:*",
    "@taskforceai/locales": "workspace:*",
    "@taskforceai/observability": "workspace:*",
    "@taskforceai/persistence": "workspace:*",
    "@taskforceai/presenters": "workspace:*",
    "@taskforceai/react-core": "workspace:*",
    "@taskforceai/sync-client": "workspace:*",
    "@taskforceai/system-runtime": "workspace:*",
    "@taskforceai/ui-kit": "workspace:*",
    "@taskforceai/voice": "workspace:*",
    "@tauri-apps/api": "^2.11.1",
    "@vercel/og": "^0.11.1",
    "ai": "^7.0.22",
    "clsx": "^2.1.1",
    "cockatiel": "^4.0.0",
    "dexie": "4.4.4",
    "dompurify": "^3.4.12",
    "i18next": "^26.3.4",
    "katex": "^0.17.0",
    "lucide-react": "^1.21.0",
    "marked": "^18.0.5",
    "prismjs": "^1.30.0",
    "qrcode": "^1.5.4",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-i18next": "^17.0.8",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.9.4",
    "@types/prismjs": "^1.26.6",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "fake-indexeddb": "^6.2.5",
    "tailwindcss": "^4.3.1",
    "vite": "8.1.4"
  },
  "packageManager": "bun@1.3.14"
}
