    "./tauri-transport": {
      "types": "./src/tauri-transport.ts",
      "default": "./src/tauri-transport.ts"
    }
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@taskforceai/client-core": "workspace:*",
    "@taskforceai/system-runtime": "workspace:*",
    "@tauri-apps/api": "^2.11.1"
