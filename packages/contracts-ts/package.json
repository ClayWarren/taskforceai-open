  "license": "MIT",
  "files": [
    "schema",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./index": "./src/index.ts",
    "./browserClient": "./src/browserClient.ts",
    "./client": "./src/client.ts",
    "./hooks": "./src/hooks.ts",
    "./contracts": "./src/contracts.ts",
    "./utils/*": "./src/utils/*.ts",
    "./api/*": "./src/api/*.ts",
