{
  "name": "@taskforceai/api-client",
  "version": "1.0.0",
  "license": "MIT",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./attachments": {
      "types": "./src/attachments.ts",
      "default": "./src/attachments.ts"
    },
    "./browserClient": {
      "types": "./src/browserClient.ts",
      "default": "./src/browserClient.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./request": {
      "types": "./src/request.ts",
      "default": "./src/request.ts"
    },
    "./api/*": {
      "types": "./src/api/*.ts",
      "default": "./src/api/*.ts"
    },
    "./auth/*": {
      "types": "./src/auth/*.ts",
      "default": "./src/auth/*.ts"
    },
    "./auth": {
      "types": "./src/auth/index.ts",
      "default": "./src/auth/index.ts"
    },
    "./services/*": {
      "types": "./src/services/*.ts",
      "default": "./src/services/*.ts"
    },
    "./utils/*": {
      "types": "./src/utils/*.ts",
      "default": "./src/utils/*.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "bench:runtime": "bun benchmarks/runtime-performance.ts"
  },
  "dependencies": {
    "@taskforceai/browser-runtime": "workspace:*",
    "@taskforceai/client-core": "workspace:*",
    "@taskforceai/contracts": "workspace:*",
    "zod": "catalog:"
  }
}
