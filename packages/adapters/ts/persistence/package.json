{
  "name": "@taskforceai/persistence",
  "version": "1.0.0",
  "license": "MIT",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./chat-normalizers": {
      "types": "./src/chat-normalizers.ts",
      "default": "./src/chat-normalizers.ts"
    },
    "./preferences/*": {
      "types": "./src/preferences/*.ts",
      "default": "./src/preferences/*.ts"
    },
    "./storage/*": {
      "types": "./src/storage/*.ts",
      "default": "./src/storage/*.ts"
    }
  },
  "dependencies": {
    "@taskforceai/client-core": "workspace:*",
    "@taskforceai/contracts": "workspace:*",
    "zod": "catalog:"
  }
}
