  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./ssr-handler": {
      "types": "./src/app/ssr-handler.ts",
      "default": "./src/app/ssr-handler.ts"
    },
    "./start": {
      "types": "./src/app/start.ts",
      "default": "./src/app/start.ts"
    },
    "./router": {
      "types": "./src/app/router.ts",
      "default": "./src/app/router.ts"
    },
    "./api-hooks": {
      "types": "./src/api/api-hooks.ts",
