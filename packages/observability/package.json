{
  "name": "@taskforceai/observability",
  "version": "0.1.0",
  "license": "MIT",
  "files": [
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./sentry-config": {
      "types": "./src/sentry-config.ts",
      "default": "./src/sentry-config.ts"
    },
    "./sentry-reporter": {
      "types": "./src/sentry-reporter.ts",
      "default": "./src/sentry-reporter.ts"
    },
    "./metrics": {
      "types": "./src/metrics.ts",
      "default": "./src/metrics.ts"
    },
    "./standard-logger": {
      "types": "./src/standard-logger.ts",
      "default": "./src/standard-logger.ts"
    }
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@sentry/nextjs": "catalog:",
    "@taskforceai/shared": "workspace:*",
    "@tauri-apps/api": "^2.11.1"
  },
  "devDependencies": {
    "@sentry/react": "catalog:",
    "@taskforceai/toolchain": "workspace:*"
  }
}
