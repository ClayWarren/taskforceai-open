{
  "name": "taskforceai-open",
  "version": "1.0.0",
  "description": "Open client and developer platform surface for TaskForceAI.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:web": "cd apps/web && bun run build",
    "build:marketing": "cd apps/marketing && bun run build",
    "build:console": "cd apps/console && bun run build",
    "build:status": "cd apps/status && bun run build",
    "build:docs": "cd apps/docs && bun run build",
    "build:sdk-typescript": "cd packages/sdk-typescript && bun run build",
    "typecheck:routes": "bun scripts/dev/generate-route-trees.ts"
  },
  "catalog": {
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3",
    "@sentry/nextjs": "^10.56.0",
    "@sentry/node": "^10.56.0",
    "@sentry/react": "^10.56.0",
    "@tanstack/react-router": "1.170.15",
    "@tanstack/react-start": "1.168.25",
    "@tanstack/router-generator": "1.170.11",
    "typescript": "npm:@typescript/native-preview@7.0.0-dev.20260612.1"
  }
}
